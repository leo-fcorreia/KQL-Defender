let TimeRange = 30d;
let MinAttempts = 30;
let LegitSuccessThreshold = 100;
let LegitDistinctUsersThreshold = 20;
let AppFilter = dynamic([
    "Azure Active Directory PowerShell",
    "Microsoft Azure PowerShell",
    "Microsoft Azure CLI",
    "Office365 Shell WCSS-Client"
]);
let ExcludedCidrs = dynamic([
    "xxx.xxx.xxx.xxx/22", "yyy.yyy.yyy.yyy/29"
]);
let LegitIPs = EntraIdSignInEvents
| where Timestamp > ago(TimeRange)
| where ErrorCode == 0
| where isnotempty(AccountUpn) and isnotempty(IPAddress)
| where LogonType has "InteractiveUser"
| summarize SuccessCountByIP = count(), SuccessfulUsersByIP = dcount(AccountUpn) by IPAddress
| where SuccessCountByIP > LegitSuccessThreshold and SuccessfulUsersByIP >= LegitDistinctUsersThreshold
| project IPAddress;
let PreviousQueryResults = EntraIdSignInEvents
| where Timestamp > ago(TimeRange)
| where ErrorCode != 0
| where isnotempty(AccountUpn) and isnotempty(IPAddress)
| where IsCompliant == 0
| where IsManaged == 0
| where LogonType has "InteractiveUser"
| where not(ipv4_is_in_any_range(IPAddress, ExcludedCidrs))
| where IPAddress !in (LegitIPs)
| extend AttackCategory = case(
    ErrorCode in (50126, 50052), "Password Spray / Brute Force",
    ErrorCode == 50053, "Account Lockout (Brute Force)",
    ErrorCode in (50076, 50078, 50079, 50178, 50181, 50184, 50177, 500121), "MFA Challenge / MFA Attack",
    ErrorCode in (700082, 700081, 70043, 50173), "Token Abuse / Session Hijack",
    ErrorCode in (53003, 53001, 53005, 53009, 53011, 53012, 530022, 530002, 530004, 530003, 530032), "Conditional Access Block",
    ErrorCode in (50020, 500011, 700016, 50105), "Account / App Enumeration",
    "Other Authentication Failure"
)
| where AttackCategory != "Other Authentication Failure" and AttackCategory != "Conditional Access Block"
| extend AppGroup = iff(isempty(tostring(Application)), "Unknown", tostring(Application))
| summarize
    Attempts = count(),
    IPAddressesArr = make_set(IPAddress),
    StartTime = min(Timestamp),
    EndTime = max(Timestamp)
by AccountUpn, AttackCategory, AppGroup
| where Attempts >= MinAttempts;
PreviousQueryResults
| mv-expand SourceIP = IPAddressesArr to typeof(string)
| summarize
    SourceAttempts = sum(Attempts),
    DistinctTargetedAccounts = dcount(AccountUpn),
    TargetedAccountsArr = make_set(AccountUpn, 100),
    AttackCategoriesArr = make_set(AttackCategory, 20),
    ApplicationsArr = make_set(AppGroup, 50),
    FirstSeen = min(StartTime),
    LastSeen = max(EndTime)
by SourceIP
| extend
    TargetedAccounts = strcat_array(TargetedAccountsArr, ", "),
    AttackCategories = strcat_array(AttackCategoriesArr, ", "),
    Applications = strcat_array(ApplicationsArr, ", "),
    // Adicionando Score e Severity fixos para teste de esquema
    SuspicionScore = tolong(10), 
    Severity = "Low"
| project
    SourceIP,
    SourceAttempts,
    DistinctTargetedAccounts,
    TargetedAccounts,
    AttackCategories,
    Applications,
    FirstSeen,
    LastSeen,
    SuspicionScore,
    Severity
//| where Applications has_any (AppFilter)
| order by SourceAttempts desc
