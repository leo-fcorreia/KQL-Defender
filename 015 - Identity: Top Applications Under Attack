let TimeRange                   = 30d;
let MinAttempts                 = 30;
let LegitSuccessThreshold       = 100;
let LegitDistinctUsersThreshold = 20;
// Exclude your Public IP Addresses
let ExcludedCidrs = dynamic([
    "xxx.xxx.xxx.xxx/22",  "yyy.yyy.yyy.yyy/29"
]);
let LegitIPs = AADSignInEventsBeta
    | where Timestamp > ago(TimeRange)
    | where ErrorCode == 0 and isnotempty(IPAddress)
    | where LogonType has "InteractiveUser"
    | summarize c = count(), u = dcount(AccountUpn) by IPAddress
    | where c > LegitSuccessThreshold and u >= LegitDistinctUsersThreshold
    | project IPAddress;
AADSignInEventsBeta
| where Timestamp > ago(TimeRange)
| where ErrorCode != 0
| where isnotempty(AccountUpn) and isnotempty(IPAddress)
| where IsCompliant == 0 and IsManaged == 0
| where LogonType has "InteractiveUser"
| where not(ipv4_is_in_any_range(IPAddress, ExcludedCidrs))
| where IPAddress !in (LegitIPs)
| extend AttackCategory = case(
    ErrorCode in (50126, 50052),                                                "Password Spray / Brute Force",
    ErrorCode == 50053,                                                         "Account Lockout (Brute Force)",
    ErrorCode in (50076, 50078, 50079, 50178, 50181, 50184, 50177, 500121),     "MFA Challenge / MFA Attack",
    ErrorCode in (700082, 700081, 70043, 50173),                                "Token Abuse / Session Hijack",
    ErrorCode in (50020, 500011, 700016, 50105),                                "Account / App Enumeration",
    "Other"
)
| where AttackCategory != "Other"
| extend AppGroup = iff(isempty(tostring(Application)), "Unknown", tostring(Application))
| summarize
    TotalAttempts   = count(),
    UniqueAccounts  = dcount(AccountUpn),
    UniqueIPs       = dcount(IPAddress),
    AttackTypes     = make_set(AttackCategory, 10),
    FirstSeen       = min(Timestamp),
    LastSeen        = max(Timestamp)
    by AppGroup
| where TotalAttempts >= MinAttempts
| extend AttackTypesSummary = strcat_array(AttackTypes, " | ")
| project
    Application     = AppGroup,
    TotalAttempts,
    UniqueAccounts,
    UniqueIPs,
    AttackTypesSummary,
    FirstSeen,
    LastSeen
| order by TotalAttempts desc
